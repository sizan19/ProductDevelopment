# ================================================================
# .env.example  —  Single config file for the ENTIRE project
# ================================================================
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. NEVER commit .env to Git  (it is already in .gitignore)
# ================================================================

# ----------------------------------------------------------------
# BACKEND — Server
# ----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ----------------------------------------------------------------
# BACKEND — PostgreSQL database
# ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=database

# ----------------------------------------------------------------
# BACKEND — JWT secret
# ----------------------------------------------------------------
JWT_SECRET=376ea99080f848fec7c056dcce75df9f052d6d3c0a35da467c89cd7aae7b3a9f

# ----------------------------------------------------------------
# BACKEND — Cloudflare Turnstile secret key (backend only)
# ----------------------------------------------------------------
TURNSTILE_SECRET_KEY=CHANGE_THIS_TO_YOUR_TURNSTILE_SECRET_KEY

# ----------------------------------------------------------------
# BACKEND — Frontend origin for CORS
# ----------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------
# FRONTEND (React) — Cloudflare Turnstile site key
# ----------------------------------------------------------------
REACT_APP_TURNSTILE_SITE_KEY=CHANGE_THIS_TO_YOUR_TURNSTILE_SITE_KEY

# ----------------------------------------------------------------
# FRONTEND (React) — Backend API base URL
# ----------------------------------------------------------------
REACT_APP_API_URL=http://localhost:5000

# ----------------------------------------------------------------
# EMAIL — For sending OTP via email (nodemailer)
# ----------------------------------------------------------------
EMAIL_USER=CHANGE_THIS_TO_YOUR_EMAIL_ADDRESS
EMAIL_PASS=CHANGE_THIS_TO_YOUR_APP_PASSWORD

# ----------------------------------------------------------------
# BACKEND — Google Gemini (AI chatbot proxy). Free key from
# https://aistudio.google.com/app/apikey  — keep this server-side only.
# ----------------------------------------------------------------
GEMINI_API_KEY=CHANGE_THIS_TO_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
